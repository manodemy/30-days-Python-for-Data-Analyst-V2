{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/supabase.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/chart.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.css|.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/landing_v2/index.html",
      "permanent": false
    },
    {
      "source": "/privacy",
      "destination": "/landing_v2/privacy.html",
      "permanent": false
    },
    {
      "source": "/terms",
      "destination": "/landing_v2/terms.html",
      "permanent": false
    },
    {
      "source": "/refund-policy",
      "destination": "/landing_v2/refund-policy.html",
      "permanent": false
    },
    {
      "source": "/reset-password",
      "destination": "/landing_v2/reset-password.html",
      "permanent": false
    },
    {
      "source": "/payment-success",
      "destination": "/landing_v2/payment-success.html",
      "permanent": false
    },
    {
      "source": "/payment-failed",
      "destination": "/landing_v2/payment-failed.html",
      "permanent": false
    }
  ]
}
